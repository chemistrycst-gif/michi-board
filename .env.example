# A Postgres connection string. Free options: Neon (neon.tech) or Supabase (supabase.com).
# It looks like: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# The password you'll use to log into /admin. Change this to something only you know.
ADMIN_PASSWORD="changeme123"

# A random long string used to sign your admin login session. Any long random text works.
SESSION_SECRET="please-change-this-to-a-long-random-string"
